{
  "name": "@get-ai-native/pretty-md",
  "version": "0.2.1",
  "description": "Instantly render any Markdown file beautifully in your browser — from the terminal.",
  "type": "module",
  "bin": {
    "pretty-md": "bin/pretty-md.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "sideEffects": false,
  "files": [
    "bin",
    "src",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc",
    "prepublishOnly": "npm test && npm run lint && npm run typecheck"
  },
  "keywords": [
    "markdown",
    "cli",
    "preview",
    "render",
    "browser",
    "pretty",
    "highlight",
    "html"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/get-ai-native/pretty-md.git"
  },
  "homepage": "https://github.com/get-ai-native/pretty-md#readme",
  "bugs": {
    "url": "https://github.com/get-ai-native/pretty-md/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@get-ai-native/pretty-md": "^0.1.3",
    "clipboardy": "^5.3.1",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.0.0",
    "playwright": "^1.59.1",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
